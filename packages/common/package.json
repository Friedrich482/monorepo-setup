{
  "name": "@repo/common",
  "version": "0.0.0",
  "private": "true",
  "exports": {
    "./*": {
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\""
  },
  "files": [
    "./dist/**"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@repo/typescript-config": "*",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
